# Admin panel: http://localhost:3000/admin/ (trailing slash matches site config)
# Use exactly 6 digits for the passcode.
ADMIN_PASSCODE=847291

# Long random secret for signing the admin session cookie (e.g. openssl rand -hex 32)
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Netlify only: Personal Access Token so admin saves can use Netlify Blobs (Site settings → Environment variables).
# Create at https://app.netlify.com/user/applications — scope must allow Blobs for this site.
# NETLIFY_AUTH_TOKEN=
